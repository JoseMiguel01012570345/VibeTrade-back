    "ReindexOnStartup": true,
    "SemanticVectorDimensions": 256
  },
  "Routing": {
    "OsrmRouteV1BaseUrl": "https://router.project-osrm.org/route/v1"
  },
  "EmailSmtp": {
    "Enabled": true,
    "Host": "TODO",
    "Port": 587,
    "User": "VibeTrade",
    "Password": "",
    "FromAddress": "vibetrademail@gmail.com",
