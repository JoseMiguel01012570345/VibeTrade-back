{
  "DemoSeed": {
    "Enabled": true,
    "DataFile": "Infrastructure/DemoData/demo-seed.json",
    "RemoveLegacyDemoData": true
  },
  "Auth": {
    "ExposeDevCodes": true
  },
  "Swagger": {
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
